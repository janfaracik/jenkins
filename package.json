{
  "name": "jenkins-ui",
  "version": "1.0.0",
  "description": "Jenkins User Interface",
  "license": "MIT",
  "author": {
    "name": "Tom Fennelly",
    "email": "tom.fennelly@gmail.com",
    "url": "https://github.com/tfennelly"
  },
  "private": true,
  "scripts": {
    "dev": "vite build --config vite.config.js --mode development",
    "prod": "vite build --config vite.config.js --mode production",
    "build": "yarn prod",
    "start": "yarn dev --watch",
    "lint:js": "eslint . && prettier --check .",
    "lint:js-ci": "eslint . -f checkstyle -o target/eslint-warnings.xml",
    "lint:css": "stylelint src/main/scss",
    "lint:css-ci": "stylelint src/main/scss --custom-formatter stylelint-checkstyle-reporter -o target/stylelint-warnings.xml",
    "lint:ci": "yarn lint:js-ci && yarn lint:css-ci",
    "lint:fix": "eslint --fix . && prettier --write . && stylelint src/main/scss --fix",
    "lint": "yarn lint:js && yarn lint:css"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.0.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-formatter-checkstyle": "9.0.1",
    "globals": "17.4.0",
    "postcss": "8.5.6",
    "postcss-preset-env": "11.2.0",
    "postcss-scss": "4.0.9",
    "prettier": "3.8.1",
    "sass": "1.97.3",
    "stylelint": "17.4.0",
    "stylelint-checkstyle-reporter": "1.1.1",
    "stylelint-config-standard-scss": "17.0.0",
    "vite": "8.0.0"
  },
  "dependencies": {
    "handlebars": "4.7.8",
    "hotkeys-js": "3.12.2",
    "jquery": "4.0.0",
    "lodash": "4.17.23",
    "sortablejs": "1.15.7",
    "tippy.js": "6.3.7",
    "window-handle": "1.0.1"
  },
  "browserslist": [
    "defaults",
    "not IE 11"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "yarn@4.12.0"
}
