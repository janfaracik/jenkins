<?jelly escape-by-default='true'?>
<j:jelly xmlns:j="jelly:core" xmlns:l="/lib/layout" xmlns:st="jelly:stapler" xmlns:f="/lib/form">
  <j:choose>
    <j:when test="${it.recentJobs.isEmpty()}">
      <p>${%empty}</p>
    </j:when>
    <j:otherwise>
      <div class="home">
        <l:app-bar title="For You" icon="${h.getUserAvatar(it.user, '64x64')}" />

        <f:section title="Builds">
          <div class="jenkins-jobs-list">
            <j:forEach var="build" items="${it.buildsThatNeedAttention}">
              <div class="jenkins-jobs-list__item">
                <div class="jenkins-jobs-list__item__details">
                  <div class="jenkins-jobs-list__item__icons">
                    <l:icon src="symbol-status-${build.iconColor.iconName}" alt="${build.iconColor.description}" />
                  </div>
                  <div class="jenkins-jobs-list__item__details__text">
                    <a class="jenkins-jobs-list__item__label" href="${build.url}">
                      <j:forEach var="parent" items="${it.getParentRecursively(build)}" varStatus="loop">
                        ${parent.name()}<l:icon src="symbol-slash" />
                      </j:forEach>
                      ${build.displayName}
                    </a>
                    <div class="jenkins-jobs-list__item__description">
                      <l:details-bar it="${build}" />
                    </div>
                  </div>
                </div>
                <div class="jenkins-jobs-list__item__actions">
                  <button class="jenkins-button jenkins-button--tertiary jenkins-jumplist-link"
                          tooltip="More actions"
                          data-href="${build.url}">
                    <l:icon src="symbol-menu" />
                  </button>
                </div>
              </div>
            </j:forEach>
          </div>
        </f:section>

        <f:section title="${%title}">
          <div class="jenkins-jobs-list">
            <j:forEach var="job" items="${it.recentJobs}">
              <div class="jenkins-jobs-list__item">
                <a class="jenkins-jobs-list__item__details" href="${job.url}">
                  <div class="jenkins-jobs-list__item__icons">
                    <l:icon src="symbol-status-${job.iconColor.iconName}" alt="${job.iconColor.description}" />
                  </div>
                  <div class="jenkins-jobs-list__item__details__text">
                    <p class="jenkins-jobs-list__item__label">
                      <j:forEach var="parent" items="${it.getParentRecursivelyJob(job)}" varStatus="loop">
                        ${parent.name()}<l:icon src="symbol-slash" />
                      </j:forEach>
                      ${job.displayName}
                    </p>
                    <div class="jenkins-jobs-list__item__description">
                      <l:details-bar it="${job}" />
                    </div>
                  </div>
                </a>
                <div class="jenkins-jobs-list__item__actions">
                  <l:actions it="${job}" compact="true" url="${job.url}" />
                </div>
              </div>
            </j:forEach>
          </div>
        </f:section>
      </div>
    </j:otherwise>
  </j:choose>
</j:jelly>
